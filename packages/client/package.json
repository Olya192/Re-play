{
  "name": "client",
  "version": "0.0.0",
  "scripts": {
    "dev": "tsc --project tsconfig.server.json && cross-env NODE_ENV=development PORT=3000 EXTERNAL_SERVER_URL='http://localhost:3001' INTERNAL_SERVER_URL='http://localhost:3001' node server/index.js",
    "build": "tsc --project tsconfig.server.json && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server",
    "preview": "node server/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest ./"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "antd": "^6.4.3",
    "@types/react-helmet": "^6.1.7",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.0.2",
    "eslint-config-prettier": "^8.5.0",
    "express": "^4.18.2",
    "prettier": "^2.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-redux": "^9.0.0",
    "react-router-dom": "^6.16.0",
    "serialize-javascript": "^6.0.1",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "@testing-library/react": "^13.3.0",
    "@types/jest": "^28.1.8",
    "@types/react": "18.2.79",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "^5.35.1",
    "@typescript-eslint/parser": "^5.35.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "classnames": "^2.5.1",
    "eslint": "^8.23.0",
    "jest": "^28",
    "jest-environment-jsdom": "^29.0.1",
    "lefthook": "^1.3.9",
    "postcss": "^8.5.14",
    "prettier": "^2.7.1",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}
